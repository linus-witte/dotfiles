{
  "layer": "top",
  "position": "bottom",
  "height": 20,
  "spacing": 8,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [],
  "modules-right": [
    "custom/sleep_delay",
    "network",
    "custom/vpn",
    "disk#root",
    "disk#shared",
    "cpu",
    "memory",
    "pulseaudio",
    "battery",
    "clock",
    "tray"
  ],
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "DP-2": [11],
      "HDMI-A-1": [12]
    }
  },
  "custom/sleep_delay": {
    "exec": "bash ~/.config/i3status/sleep_delay.sh waybar",
    "interval": 1,
    "return-type": "json"
  },
  "network": {
    "format-wifi": "wifi: {essid} {ipaddr}",
    "format-ethernet": "eth: {ipaddr}",
    "format-disconnected": "eth: down",
    "tooltip-format": "{ifname}"
  },
  "custom/vpn": {
    "exec": "bash ~/.config/waybar/vpn_ip.sh",
    "interval": 5,
    "return-type": "json"
  },
  "disk#root": {
    "path": "/",
    "format": "os: {free}"
  },
  "disk#shared": {
    "path": "/mnt/shared",
    "format": "shared: {free}"
  },
  "cpu": {
    "format": "load: {load}"
  },
  "memory": {
    "format": "ram: {used:0.1f}/{avail:0.1f} GB",
    "states": {
      "warning": 85,
      "critical": 95
    }
  },
  "pulseaudio": {
    "format": "vol: {volume}%",
    "format-muted": "vol: muted"
  },
  "battery": {
    "format": "bat: BAT {capacity}% {time}",
    "format-charging": "bat: CHR {capacity}% {time}",
    "format-plugged": "bat: FULL {capacity}%",
    "format-full": "bat: FULL {capacity}%"
  },
  "clock": {
    "interval": 1,
    "format": "{:%Y-%m-%d %H:%M:%S}"
  },
  "tray": {
    "spacing": 6
  }
}
