# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 1
        output_format = "i3bar"
}

order += "wireless _first_"
order += "ethernet _first_"
order += "ethernet tun0"
order += "disk /"
order += "load"
order += "memory"
order += "volume master"
order += "battery all"
order += "tztime local"

wireless _first_ {
        format_up = "W: %essid %ip"
        format_down = "W: down"
}

ethernet _first_ {
        format_up = "E: %ip"
        format_down = "E: down"
}

ethernet tun0 {
        format_up = "VPN: %ip"
        format_down = ""
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

memory {
        format = "%used | %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

volume master {
        format = "VOL: %volume"
        format_muted = "VOL: muted"
        device = "default"
        mixer = "Master"
}

battery all {
        format = "%status %percentage %remaining"
        format_down = ""
}

tztime local {
        format = "%Y-%m-%d %H:%M:%S"
}
